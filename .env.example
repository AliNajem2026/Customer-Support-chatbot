# Anthropic API key — get yours at https://console.anthropic.com
# Must start with sk-ant-api03-
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Claude model to use for classification and response generation
CLAUDE_MODEL=claude-sonnet-4-6

# Path to the saved FAISS vector index (generated by: python -m vectorstore.ingest)
FAISS_INDEX_PATH=vectorstore/faiss_index

# Path for the interaction log CSV
LOG_FILE=logs/interactions.csv

# Backend URL used by the Streamlit frontend
# Local development: http://localhost:8000
# Docker:           http://backend:8000
BACKEND_URL=http://localhost:8000
